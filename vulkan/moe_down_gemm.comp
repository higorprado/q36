#version 460

#extension GL_EXT_shader_16bit_storage : require
#extension GL_EXT_shader_explicit_arithmetic_types_int8 : require
#extension GL_EXT_shader_explicit_arithmetic_types_float16 : require

/* Routed Q2_K down projection GEMM for prefill batches: one workgroup
 * owns a 64-out-row x 16-slot tile of one expert's token group. Weights
 * dequantize fully (d*sc*q - dmin*m) into shared f16 once per 32-element
 * k-block and apply to all 16 slots' SwiGLU mid rows through packed f16
 * FMAs; partial sums flush to f32 accumulators per k-block. Same
 * numerics posture as the gate/up GEMM: fixed per-output k order for
 * any n_tok, ~1e-3 from the decode matvec, covered by the relaxed
 * warm==cold session gate. */

layout(local_size_x = 256, local_size_y = 1, local_size_z = 1) in;

layout(set = 0, binding = 0) readonly buffer Weights { uint16_t wb[]; };
layout(set = 0, binding = 1) readonly buffer Mid { vec4 mid[]; };
layout(set = 0, binding = 2) readonly buffer Tiles { uint tiles[]; };
layout(set = 0, binding = 3) readonly buffer Scales { float scales[]; };
layout(set = 0, binding = 4) writeonly buffer Output { float y[]; };

layout(push_constant) uniform Push {
    uint out_dim;
    uint in_dim;
    uint blocks;
    uint n_used;
    uint has_scales;
    uint pad;
} pc;

/* One Q2_K superblock is 42 uint16 words:
 * [8 x scales][32 x qs][dm.x f16][dm.y f16]. */
const uint Q2K_U16 = 42u;
const uint SLOT_TILE = 16u;
const uint TILE_WORDS = 1u + SLOT_TILE;
const uint INVALID = 0xffffffffu;
const uint BM = 64u;
const uint KK = 8u;

shared f16vec4 As[BM][KK + 1u];
shared f16vec4 Bs[SLOT_TILE][KK + 1u];
shared uint sh_slot[SLOT_TILE];

void main(void) {
    uint tid = gl_LocalInvocationID.x;
    uint row0 = gl_WorkGroupID.x * BM;
    uint tile_base = gl_WorkGroupID.y * TILE_WORDS;
    uint expert = tiles[tile_base];
    if (expert == INVALID) return;

    if (tid < SLOT_TILE) sh_slot[tid] = tiles[tile_base + 1u + tid];

    uint row_u16 = pc.blocks * Q2K_U16;
    uint ar = tid >> 2u;      /* staged row 0..63 */
    uint sub = tid & 3u;      /* 8-element group within the 32-block */
    uint row = row0 + ar;
    uint base_u16 = (expert * pc.out_dim + (row < pc.out_dim ? row : 0u)) * row_u16;
    uint bc = tid >> 3u;
    uint bkk = tid & 7u;
    uint tx = tid & 15u;
    uint ty = tid >> 4u;
    uint mid4 = pc.in_dim / 4u;

    float acc[4];
    for (uint i = 0u; i < 4u; i++) acc[i] = 0.0;
    barrier();

    uint n_kb = pc.blocks * 8u;
    for (uint kb = 0u; kb < n_kb; kb++) {
        uint sb = kb >> 3u;
        uint half_ = (kb >> 2u) & 1u;   /* 128-element half of the superblock */
        uint j = kb & 3u;               /* 2-bit shift within the half */
        /* Stage A: dequantize 8 elements. Element n = 128*half + 32*j + l
         * uses qs byte l of the half at shift 2j, scale group n >> 4. */
        {
            uint bb = base_u16 + sb * Q2K_U16;
            vec2 dm = unpackHalf2x16(uint(wb[bb + 40u]) | (uint(wb[bb + 41u]) << 16u));
            uint g = 8u * half_ + 2u * j + (sub >> 1u);
            uint scw = (uint(wb[bb + (g >> 1u)]) >> (8u * (g & 1u))) & 255u;
            float sc1 = dm.x * float(scw & 0xFu);
            float sc2 = dm.y * float((scw >> 4u) & 0xFu);
            uint q0w = bb + 8u + 16u * half_ + sub * 4u;
            uint p0 = uint(wb[q0w + 0u]) | (uint(wb[q0w + 1u]) << 16u);
            uint p1 = uint(wb[q0w + 2u]) | (uint(wb[q0w + 3u]) << 16u);
            vec4 q0 = vec4(unpack8((p0 >> (2u * j)) & 0x03030303u));
            vec4 q1 = vec4(unpack8((p1 >> (2u * j)) & 0x03030303u));
            As[ar][sub * 2u] = f16vec4(q0 * sc1 - sc2);
            As[ar][sub * 2u + 1u] = f16vec4(q1 * sc1 - sc2);
        }
        /* Stage B: 16 slots x 32 mid elements, rounded once to f16. */
        if (bc < SLOT_TILE) {
            uint slot = sh_slot[bc];
            Bs[bc][bkk] = slot != INVALID ? f16vec4(mid[slot * mid4 + kb * 8u + bkk])
                                          : f16vec4(0.0hf);
        }
        barrier();

        f16vec2 pk[4];
        for (uint i = 0u; i < 4u; i++) pk[i] = f16vec2(0.0hf);
        for (uint kk = 0u; kk < KK; kk++) {
            f16vec4 b = Bs[tx][kk];
            for (uint i = 0u; i < 4u; i++) {
                f16vec4 a = As[ty + 16u * i][kk];
                pk[i] = fma(a.zw, b.zw, fma(a.xy, b.xy, pk[i]));
            }
        }
        for (uint i = 0u; i < 4u; i++) acc[i] += float(pk[i].x) + float(pk[i].y);
        barrier();
    }

    uint slot = sh_slot[tx];
    if (slot == INVALID) return;
    float sc = pc.has_scales != 0u ? scales[expert] : 1.0;
    for (uint i = 0u; i < 4u; i++) {
        uint r = row0 + ty + 16u * i;
        if (r < pc.out_dim) y[slot * pc.out_dim + r] = acc[i] * sc;
    }
}
