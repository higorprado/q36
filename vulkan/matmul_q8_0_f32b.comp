#version 460

#extension GL_EXT_shader_16bit_storage : require
#extension GL_EXT_shader_explicit_arithmetic_types_int8 : require
#extension GL_KHR_shader_subgroup_basic : require
#extension GL_KHR_shader_subgroup_arithmetic : require

/* Decode Q8_0 matvec against raw f32 activations. Unlike the Q8xQ8 decode
 * kernels this skips activation quantization entirely, so the runtime never
 * has to read the hidden state back to the host before a dense projection.
 * Weights stay in the mmap'd 34-byte Q8_0 blocks; the 16-bit typed view
 * keeps every load aligned (block byte offset is always even). */

layout(local_size_x = 64, local_size_y = 1, local_size_z = 1) in;

layout(set = 0, binding = 0) readonly buffer Weights {
    uint16_t wb16[];
};

layout(set = 0, binding = 1) readonly buffer X {
    vec4 xv[];
};

layout(set = 0, binding = 2) writeonly buffer Output {
    float y[];
};

layout(push_constant) uniform Push {
    uint out_dim;
    uint n_tok;
    uint blocks;
    uint row_bytes;
    float scale;
} pc;

/* One Q8_0 block is 17 uint16 words: [d_f16][16 x 2 qs bytes]. */
const uint Q8_0_U16 = 17u;

shared float sh_sub[4];

void main(void) {
    uint tid = gl_LocalInvocationID.x;
    /* y splits the row range so the vocab head fits the 65535 group limit. */
    uint row = gl_WorkGroupID.y * 16384u + gl_WorkGroupID.x;
    if (row >= pc.out_dim) return;
    uint row_base = row * pc.blocks * Q8_0_U16;
    /* Thread t covers 8 consecutive elements: block (t>>2), byte pair
     * (t&3)*8. 64 threads span 16 blocks per iteration. */
    uint bstep = gl_WorkGroupSize.x >> 2u;
    uint boff = tid >> 2u;
    uint eoff = (tid & 3u) * 8u;
    float acc = 0.0;

    for (uint b = boff; b < pc.blocks; b += bstep) {
        uint base = row_base + b * Q8_0_U16;
        float d = unpackHalf2x16(uint(wb16[base])).x;
        uint q = base + 1u + (eoff >> 1u);
        uint p0 = uint(wb16[q + 0u]) | (uint(wb16[q + 1u]) << 16u);
        uint p1 = uint(wb16[q + 2u]) | (uint(wb16[q + 3u]) << 16u);
        vec4 w0 = vec4(unpack8(int(p0)));
        vec4 w1 = vec4(unpack8(int(p1)));
        uint xi = (b * 32u + eoff) >> 2u;
        acc += d * (dot(w0, xv[xi]) + dot(w1, xv[xi + 1u]));
    }

    acc = subgroupAdd(acc);
    if (gl_NumSubgroups > 1u) {
        if (subgroupElect()) sh_sub[gl_SubgroupID] = acc;
        barrier();
        if (tid == 0u) {
            acc = sh_sub[0];
            for (uint i = 1u; i < gl_NumSubgroups; i++) acc += sh_sub[i];
        }
    }
    if (tid == 0u) y[row] = acc * pc.scale;
}
