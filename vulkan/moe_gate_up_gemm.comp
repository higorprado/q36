#version 460

#extension GL_EXT_shader_16bit_storage : require
#extension GL_EXT_shader_explicit_arithmetic_types_int8 : require
#extension GL_EXT_shader_explicit_arithmetic_types_float16 : require

/* Routed IQ2_XXS gate/up/SwiGLU GEMM for prefill batches: one workgroup
 * owns a 64-mid-row x 16-slot tile of one expert's token group. The
 * expert row block dequantizes into shared memory once per k-block and
 * is applied to all 16 slots through packed f16 FMAs, so the dequant
 * and weight traffic amortize over the tile instead of per 8 routed
 * pairs, and no subgroup reduction runs at all.
 *
 * Numerics: grid values stage as +/-grid * 2^-6 (exact in f16, grid
 * <= 43) and activations round once to f16; packed even/odd-k partial
 * sums flush to f32 accumulators every 32-element scale group with the
 * group scale (db * 64) folded in. Per-output k order is fixed for any
 * n_tok, but the order differs from the decode matvec: prefill and
 * decode numerics diverge by ~1e-3, which the relaxed strict (not
 * bit-exact) warm==cold session gate absorbs. */

layout(local_size_x = 256, local_size_y = 1, local_size_z = 1) in;

layout(set = 0, binding = 0) readonly buffer GateWeights { uint16_t gw[]; };
layout(set = 0, binding = 1) readonly buffer UpWeights { uint16_t uw[]; };
layout(set = 0, binding = 2) readonly buffer X { vec4 xv[]; };
layout(set = 0, binding = 3) readonly buffer Tiles { uint tiles[]; };
layout(set = 0, binding = 4) readonly buffer GateScales { float gate_scales[]; };
layout(set = 0, binding = 5) readonly buffer UpScales { float up_scales[]; };
layout(set = 0, binding = 6) writeonly buffer Output { float y[]; };
layout(set = 0, binding = 7) readonly buffer Tables { uint tables[]; };

layout(push_constant) uniform Push {
    uint mid_dim;
    uint blocks;
    uint n_used;
    uint has_gate_scales;
    uint has_up_scales;
    uint pad;
} pc;

/* One IQ2_XXS superblock is 33 uint16 words: [d_f16][32 x qs words]. */
const uint IQ2_U16 = 33u;
const uint SLOT_TILE = 16u;
const uint TILE_WORDS = 1u + SLOT_TILE;
const uint INVALID = 0xffffffffu;
const uint BM = 64u;
const uint KK = 8u;

shared uint sh_grid[512];
/* [m][kk] f16vec4 lanes, one pad slot against LDS bank conflicts. */
shared f16vec4 Ag[BM][KK + 1u];
shared f16vec4 Au[BM][KK + 1u];
shared f16vec4 Bs[SLOT_TILE][KK + 1u];
shared float Dg[BM];
shared float Du[BM];
shared uint sh_slot[SLOT_TILE];
shared uint sh_x4[SLOT_TILE];

void main(void) {
    uint tid = gl_LocalInvocationID.x;
    uint row0 = gl_WorkGroupID.x * BM;
    uint tile_base = gl_WorkGroupID.y * TILE_WORDS;
    uint expert = tiles[tile_base];
    if (expert == INVALID) return;

    if (tid < SLOT_TILE) {
        uint slot = tiles[tile_base + 1u + tid];
        sh_slot[tid] = slot;
        sh_x4[tid] = (slot != INVALID ? slot / pc.n_used : 0u) * pc.blocks * 64u;
    }
    for (uint w = tid; w < 512u; w += 256u) sh_grid[w] = tables[w];

    uint row_u16 = pc.blocks * IQ2_U16;
    uint ar = tid >> 2u;      /* staged row 0..63 */
    uint sub = tid & 3u;      /* 8-element group within the 32-block */
    uint row = row0 + ar;
    uint base_u16 = (expert * pc.mid_dim + (row < pc.mid_dim ? row : 0u)) * row_u16;
    uint bc = tid >> 3u;      /* staged slot 0..31 -> first 16 live */
    uint bkk = tid & 7u;
    uint tx = tid & 15u;      /* output slot lane */
    uint ty = tid >> 4u;      /* output row lane: rows ty + 16*i */

    float accg[4];
    float accu[4];
    for (uint i = 0u; i < 4u; i++) {
        accg[i] = 0.0;
        accu[i] = 0.0;
    }
    barrier();

    uint n_kb = pc.blocks * 8u;
    for (uint kb = 0u; kb < n_kb; kb++) {
        uint sb = kb >> 3u;
        uint ib32 = kb & 7u;
        /* Stage gate and up: 64 rows x one 32-element scale group, one
         * 8-element grid word per thread. */
        {
            uint gb = base_u16 + sb * IQ2_U16;
            uint gq = gb + 1u + 4u * ib32;
            uint gss = uint(gw[gq + 2u]) | (uint(gw[gq + 3u]) << 16u);
            uint uss = uint(uw[gq + 2u]) | (uint(uw[gq + 3u]) << 16u);
            uint gqs = (uint(gw[gq + (sub >> 1u)]) >> (8u * (sub & 1u))) & 255u;
            uint uqs = (uint(uw[gq + (sub >> 1u)]) >> (8u * (sub & 1u))) & 255u;
            uint sbit = 7u * sub;

            uint gsign = bitfieldExtract(gss, int(sbit), 7);
            vec4 g0 = vec4(unpack8(sh_grid[gqs * 2u]));
            vec4 g1 = vec4(unpack8(sh_grid[gqs * 2u + 1u]));
            g0 = mix(g0, -g0, bvec4((gsign & 1u) != 0u, (gsign & 2u) != 0u, (gsign & 4u) != 0u, (gsign & 8u) != 0u));
            g1 = mix(g1, -g1, bvec4((gsign & 16u) != 0u, (gsign & 32u) != 0u, (gsign & 64u) != 0u, (bitCount(gsign) & 1) != 0));
            Ag[ar][sub * 2u] = f16vec4(g0 * 0.015625);
            Ag[ar][sub * 2u + 1u] = f16vec4(g1 * 0.015625);

            uint usign = bitfieldExtract(uss, int(sbit), 7);
            vec4 u0 = vec4(unpack8(sh_grid[uqs * 2u]));
            vec4 u1 = vec4(unpack8(sh_grid[uqs * 2u + 1u]));
            u0 = mix(u0, -u0, bvec4((usign & 1u) != 0u, (usign & 2u) != 0u, (usign & 4u) != 0u, (usign & 8u) != 0u));
            u1 = mix(u1, -u1, bvec4((usign & 16u) != 0u, (usign & 32u) != 0u, (usign & 64u) != 0u, (bitCount(usign) & 1) != 0));
            Au[ar][sub * 2u] = f16vec4(u0 * 0.015625);
            Au[ar][sub * 2u + 1u] = f16vec4(u1 * 0.015625);

            if (sub == 0u) {
                float gd = unpackHalf2x16(uint(gw[gb])).x;
                float ud = unpackHalf2x16(uint(uw[gb])).x;
                Dg[ar] = gd * 0.25 * (0.5 + float(gss >> 28u)) * 64.0;
                Du[ar] = ud * 0.25 * (0.5 + float(uss >> 28u)) * 64.0;
            }
        }
        /* Stage B: 16 slots x 32 elements, rounded once to f16. */
        if (bc < SLOT_TILE) {
            bool live = sh_slot[bc] != INVALID;
            Bs[bc][bkk] = live ? f16vec4(xv[sh_x4[bc] + kb * 8u + bkk]) : f16vec4(0.0hf);
        }
        barrier();

        f16vec2 pkg[4];
        f16vec2 pku[4];
        for (uint i = 0u; i < 4u; i++) {
            pkg[i] = f16vec2(0.0hf);
            pku[i] = f16vec2(0.0hf);
        }
        for (uint kk = 0u; kk < KK; kk++) {
            f16vec4 b = Bs[tx][kk];
            for (uint i = 0u; i < 4u; i++) {
                f16vec4 ag = Ag[ty + 16u * i][kk];
                f16vec4 au = Au[ty + 16u * i][kk];
                pkg[i] = fma(ag.zw, b.zw, fma(ag.xy, b.xy, pkg[i]));
                pku[i] = fma(au.zw, b.zw, fma(au.xy, b.xy, pku[i]));
            }
        }
        for (uint i = 0u; i < 4u; i++) {
            accg[i] = fma(Dg[ty + 16u * i], float(pkg[i].x) + float(pkg[i].y), accg[i]);
            accu[i] = fma(Du[ty + 16u * i], float(pku[i].x) + float(pku[i].y), accu[i]);
        }
        barrier();
    }

    uint slot = sh_slot[tx];
    if (slot == INVALID) return;
    float gsc = pc.has_gate_scales != 0u ? gate_scales[expert] : 1.0;
    float usc = pc.has_up_scales != 0u ? up_scales[expert] : 1.0;
    for (uint i = 0u; i < 4u; i++) {
        uint r = row0 + ty + 16u * i;
        if (r >= pc.mid_dim) continue;
        float g = accg[i] * gsc;
        float v = accu[i] * usc;
        y[slot * pc.mid_dim + r] = (g / (1.0f + exp(-g))) * v;
    }
}
