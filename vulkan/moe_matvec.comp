#version 460
#extension GL_ARB_gpu_shader_int64 : require

/* Routed-expert matvec for Q2_K / Q4_K / Q5_K / Q6_K / IQ2_XXS / IQ2_S / IQ3_S expert quants against
 * q8_K-quantized activations, bit-exact replica of the ggml AVX2 vec_dot
 * kernels the CPU engine links (ggml_vec_dot_iq2_*_q8_K / iq3_s in
 * ggml-cpu/arch/x86/quants.c).  One workgroup owns one expert-major routed
 * pair tile and 8 output rows: the tiles buffer names the expert plus up to
 * eight pair ids, so each expert row block is loaded once and applied to
 * independent q8_K accumulation chains before advancing.  The optional scales
 * buffer is the per-expert .scale tensor applied to the matvec output,
 * mirroring q36_scale_inplace(); in fallback staging mode it is packed one
 * entry per tile instead.
 *
 * AVX2 keeps 8 float accumulator lanes: lane k carries, per 256-block, the
 * integer dot of elements 32*ib + 4k .. +3 over every 32-element sub-block
 * ib, times the (2*ls+1) sub-block scale, fma-accumulated with the block
 * scale d, reduced in hsum_float_8 pair order (iq2 kernels scale the total
 * by 0.125 at the very end).  Integer sums are exact in both worlds, so
 * matching the float skeleton makes a row dot bit-equal to the CPU.  The 8
 * lanes are independent serial chains, so each runs on its own GPU thread
 * (8 rows x 8 lanes per workgroup) and one thread combines them in the exact
 * pair order.
 *
 * The tables buffer packs the codebook grids, built once by the runtime:
 *   words [0,512)      iq2xxs_grid (256 x 8 bytes)
 *   words [512,544)    ksigns_iq2xs (128 bytes)
 *   words [544,2592)   iq2s_grid (1024 x 8 bytes)
 *   words [2592,3104)  iq3s_grid (512 x 4 bytes)
 *
 * x_per_expert selects whether a pair uses token row tok (gate/up fed by the
 * token activation) or pair row tok*n_used+slot (down fed by that expert's
 * swiglu output). */

layout(local_size_x = 64, local_size_y = 1, local_size_z = 1) in;

layout(set = 0, binding = 0) readonly buffer Weights {
    uint wb[];
};

layout(set = 0, binding = 1) readonly buffer Q8K {
    uint q8[];
};

layout(set = 0, binding = 2) readonly buffer Tiles {
    uint tiles[];
};

layout(set = 0, binding = 3) readonly buffer Scales {
    float scales[];
};

layout(set = 0, binding = 4) writeonly buffer Output {
    float y[];
};

layout(set = 0, binding = 5) readonly buffer Tables {
    uint tables[];
};

layout(push_constant) uniform Push {
    uint out_dim;
    uint blocks;
    uint row_bytes;
    uint expert_stride;
    uint type;
    uint n_used;
    uint has_scales;
    uint x_per_expert;
    uint packed_weights;
} pc;

const uint Q2_K = 10u;
const uint Q4_K = 12u;
const uint Q5_K = 13u;
const uint Q6_K = 14u;
const uint IQ2_XXS = 16u;
const uint IQ3_S = 21u;
const uint IQ2_S = 22u;

const uint TAB_XXS_GRID = 0u;
const uint TAB_KSIGNS = 512u;
const uint TAB_IQ2S_GRID = 544u;
const uint TAB_IQ3S_GRID = 2592u;

const uint PAIR_TILE = 8u;
const uint TILE_WORDS = 1u + PAIR_TILE;
const uint INVALID_PAIR = 0xffffffffu;
const uint Q8K_WORDS = 74u;

shared float sh_lane[64u * PAIR_TILE];
shared float sh_min[64u * PAIR_TILE];
shared uint sh_q8[Q8K_WORDS * PAIR_TILE];

uint load_u8(uint off) {
    return (wb[off >> 2] >> ((off & 3u) * 8u)) & 255u;
}

uint load_u16(uint off) {
    return load_u8(off) | (load_u8(off + 1u) << 8);
}

int load_i8(uint off) {
    uint v = load_u8(off);
    return v >= 128u ? int(v) - 256 : int(v);
}

float load_f16(uint off) {
    return unpackHalf2x16(load_u16(off)).x;
}

uint tab_u8(uint word_base, uint byte_idx) {
    return (tables[word_base + (byte_idx >> 2)] >> ((byte_idx & 3u) * 8u)) & 255u;
}

int q8_i8(uint pair_slot, uint idx) {
    uint v = (sh_q8[pair_slot * Q8K_WORDS + 2u + (idx >> 2)] >> ((idx & 3u) * 8u)) & 255u;
    return v >= 128u ? int(v) - 256 : int(v);
}

float q8_d(uint pair_slot) {
    return uintBitsToFloat(sh_q8[pair_slot * Q8K_WORDS]);
}

int q8_bsum(uint pair_slot, uint idx) {
    uint word = sh_q8[pair_slot * Q8K_WORDS + 66u + (idx >> 1)];
    uint v = ((idx & 1u) == 0u) ? (word & 65535u) : (word >> 16);
    return v >= 32768u ? int(v) - 65536 : int(v);
}

uint q2_value(uint base, uint idx) {
    uint in_idx = idx & 127u;
    uint qoff = base + 16u + (idx >> 7u) * 32u + (in_idx & 31u);
    return (load_u8(qoff) >> ((in_idx >> 5u) * 2u)) & 3u;
}

uint q2_scale(uint base, uint group16) {
    return load_u8(base + group16) & 15u;
}

uint q2_min(uint base, uint group16) {
    return load_u8(base + group16) >> 4;
}

void k4_scale_min(uint base, uint j, out uint scale, out uint mn) {
    uint s0 = load_u8(base + 4u + j);
    if (j < 4u) {
        scale = s0 & 63u;
        mn = load_u8(base + 8u + j) & 63u;
    } else {
        uint sj4 = load_u8(base + 4u + j + 4u);
        uint sjm4 = load_u8(base + 4u + j - 4u);
        scale = (sj4 & 15u) | ((sjm4 >> 6) << 4);
        mn = (sj4 >> 4) | ((s0 >> 6) << 4);
    }
}

uint q4_value(uint base, uint idx) {
    uint g = idx >> 5;
    uint i = idx & 31u;
    uint b = load_u8(base + 16u + (g >> 1) * 32u + i);
    return ((g & 1u) == 0u) ? (b & 15u) : (b >> 4);
}

uint q5_value(uint base, uint idx) {
    uint g = idx >> 5u;
    uint i = idx & 31u;
    uint b = load_u8(base + 48u + (g >> 1u) * 32u + i);
    uint lo = ((g & 1u) == 0u) ? (b & 15u) : (b >> 4u);
    uint hi = (load_u8(base + 16u + i) >> g) & 1u;
    return lo | (hi << 4u);
}

uint q6_value(uint base, uint idx) {
    uint half_block = idx >> 7u;
    uint in_idx = idx & 127u;
    uint l = in_idx & 31u;
    uint sel = in_idx >> 5u;
    uint ql_off = half_block * 64u + (((sel & 1u) == 1u) ? 32u : 0u) + l;
    uint low = (sel < 2u) ? (load_u8(base + ql_off) & 15u)
                          : (load_u8(base + ql_off) >> 4u);
    uint hi = (load_u8(base + 128u + half_block * 32u + l) >> (sel * 2u)) & 3u;
    return low | (hi << 4u);
}

/* Signed sum over 4 quants: grid byte * q8 with per-quant sign bits taken
 * from `signs` starting at bit `bit0`.  One AVX2 int32 lane. */
int signed_grid4(uint grid_word_base, uint grid_byte0, uint signs, uint bit0,
                 uint qbase, uint q8_off) {
    int sumi = 0;
    for (uint j = 0u; j < 4u; j++) {
        uint byte_idx = grid_byte0 + j;
        uint g = (tables[grid_word_base + (byte_idx >> 2)] >> ((byte_idx & 3u) * 8u)) & 255u;
        int prod = int(g) * q8_i8(qbase, q8_off + j);
        sumi += ((signs >> (bit0 + j)) & 1u) != 0u ? -prod : prod;
    }
    return sumi;
}


/* Correctly rounded f32 fused multiply-add.  The f32 product is exact in
 * fp64; the sum is rounded to odd (Boldo-Melquiond) so the final f32
 * conversion rounds exactly like a hardware fma.  Mesa does not reliably
 * keep GLSL fma() fused, and a plain fp64 mul+add double-rounds on rare
 * tie values, which is enough to break CPU parity. */
float fma32(float a, float b, float c) {
    double p = double(a) * double(b);
    double s = p + double(c);
    double bv = s - p;
    double e = (p - (s - bv)) + (double(c) - bv);
    if (e != 0.0LF) {
        uint64_t bits = doubleBitsToUint64(s);
        if ((bits & 1UL) == 0UL) {
            if (s > 0.0LF) bits += (e > 0.0LF) ? 1UL : -1UL;
            else if (s < 0.0LF) bits += (e < 0.0LF) ? 1UL : -1UL;
            s = uint64BitsToDouble(bits);
        }
    }
    return float(s);
}

void main(void) {
    uint lid = gl_LocalInvocationID.x;
    uint row = gl_WorkGroupID.x * 8u + (lid >> 3);
    uint tile = gl_WorkGroupID.y;
    uint k = lid & 7u;
    bool row_live = row < pc.out_dim;
    uint tile_base = tile * TILE_WORDS;
    uint expert = tiles[tile_base];
    if (expert == 0xffffffffu) return;
    uint weight_idx = (pc.packed_weights != 0u) ? tile : expert;

    uint row_base = weight_idx * pc.expert_stride + (row_live ? row : 0u) * pc.row_bytes;
    uint block_bytes = pc.row_bytes / pc.blocks;
    uint pair[PAIR_TILE];
    bool pair_valid[PAIR_TILE];
    bool pair_live[PAIR_TILE];
    uint qbase[PAIR_TILE];

    /* This thread carries AVX2 lane k of its row, a serial fma32 chain over
     * the blocks exactly like the intrinsics. */
    float lane[PAIR_TILE];
    float mins[PAIR_TILE];
    for (uint u = 0u; u < PAIR_TILE; u++) {
        uint p = tiles[tile_base + 1u + u];
        uint tok = (p != INVALID_PAIR) ? (p / pc.n_used) : 0u;
        pair[u] = p;
        pair_valid[u] = p != INVALID_PAIR;
        pair_live[u] = row_live && pair_valid[u];
        qbase[u] = (pair_valid[u] ? ((pc.x_per_expert != 0u) ? p : tok) : 0u) * pc.blocks * Q8K_WORDS;
        lane[u] = 0.0;
        mins[u] = 0.0;
    }

    for (uint b = 0u; b < pc.blocks; b++) {
        for (uint u = 0u; u < PAIR_TILE; u++) {
            uint q8b = qbase[u] + b * Q8K_WORDS;
            for (uint w = lid; w < Q8K_WORDS; w += 64u) {
                if (pair_valid[u]) sh_q8[u * Q8K_WORDS + w] = q8[q8b + w];
                else sh_q8[u * Q8K_WORDS + w] = 0u;
            }
        }
        barrier();

        if (row_live) {
            float yd[PAIR_TILE];
            for (uint u = 0u; u < PAIR_TILE; u++) yd[u] = pair_valid[u] ? q8_d(u) : 0.0;
            uint base = row_base + b * block_bytes;
            float wd = load_f16(base);

            if (pc.type == Q2_K) {
                float wdmin = load_f16(base + 82u);
                wd = load_f16(base + 80u);
                int lk[PAIR_TILE];
                for (uint u = 0u; u < PAIR_TILE; u++) lk[u] = 0;
                for (uint u = 0u; u < PAIR_TILE; u++) {
                    if (!pair_live[u]) continue;
                    int minprod = int(q2_min(base, 2u * k)) * q8_bsum(u, 2u * k)
                                + int(q2_min(base, 2u * k + 1u)) * q8_bsum(u, 2u * k + 1u);
                    lane[u] = fma32(-yd[u] * wdmin, float(minprod), lane[u]);
                }
                for (uint hb = 0u; hb < 2u; hb++) {
                    for (uint s = 0u; s < 4u; s++) {
                        uint group16 = hb * 8u + 2u * s + (k >= 4u ? 1u : 0u);
                        uint e = hb * 128u + s * 32u + (k < 4u ? 4u * k : 16u + 4u * (k - 4u));
                        int qv0 = int(q2_value(base, e + 0u));
                        int qv1 = int(q2_value(base, e + 1u));
                        int qv2 = int(q2_value(base, e + 2u));
                        int qv3 = int(q2_value(base, e + 3u));
                        int wsc = int(q2_scale(base, group16));
                        for (uint u = 0u; u < PAIR_TILE; u++) {
                            if (!pair_live[u]) continue;
                            int s4 = qv0 * q8_i8(u, e + 0u)
                                   + qv1 * q8_i8(u, e + 1u)
                                   + qv2 * q8_i8(u, e + 2u)
                                   + qv3 * q8_i8(u, e + 3u);
                            lk[u] += wsc * s4;
                        }
                    }
                }
                for (uint u = 0u; u < PAIR_TILE; u++) {
                    if (pair_live[u]) lane[u] = fma32(wd * yd[u], float(lk[u]), lane[u]);
                }
            } else if (pc.type == Q4_K) {
                uint sc[8];
                uint mn[8];
                float wd = load_f16(base + 0u);
                float wdmin = load_f16(base + 2u);
                for (uint g = 0u; g < 8u; g++) k4_scale_min(base, g, sc[g], mn[g]);
                if (k < 4u) {
                    int mn0 = int(mn[2u * k]);
                    int mn1 = int(mn[2u * k + 1u]);
                    for (uint u = 0u; u < PAIR_TILE; u++) {
                        if (!pair_live[u]) continue;
                        int prod = mn0 * (q8_bsum(u, 4u * k) + q8_bsum(u, 4u * k + 1u))
                                 + mn1 * (q8_bsum(u, 4u * k + 2u) + q8_bsum(u, 4u * k + 3u));
                        mins[u] = fma32(-yd[u] * wdmin, float(prod), mins[u]);
                    }
                }
                int lk[PAIR_TILE];
                for (uint u = 0u; u < PAIR_TILE; u++) lk[u] = 0;
                for (uint g = 0u; g < 8u; g++) {
                    uint e = 32u * g + 4u * k;
                    int qv0 = int(q4_value(base, e + 0u));
                    int qv1 = int(q4_value(base, e + 1u));
                    int qv2 = int(q4_value(base, e + 2u));
                    int qv3 = int(q4_value(base, e + 3u));
                    int wsc = int(sc[g]);
                    for (uint u = 0u; u < PAIR_TILE; u++) {
                        if (!pair_live[u]) continue;
                        int s4 = qv0 * q8_i8(u, e + 0u)
                               + qv1 * q8_i8(u, e + 1u)
                               + qv2 * q8_i8(u, e + 2u)
                               + qv3 * q8_i8(u, e + 3u);
                        lk[u] += wsc * s4;
                    }
                }
                for (uint u = 0u; u < PAIR_TILE; u++) {
                    if (pair_live[u]) lane[u] = fma32(wd * yd[u], float(lk[u]), lane[u]);
                }
            } else if (pc.type == Q5_K) {
                uint sc[8];
                uint mn[8];
                float wd = load_f16(base + 0u);
                float wdmin = load_f16(base + 2u);
                for (uint g = 0u; g < 8u; g++) k4_scale_min(base, g, sc[g], mn[g]);
                if (k == 0u) {
                    for (uint u = 0u; u < PAIR_TILE; u++) {
                        if (!pair_live[u]) continue;
                        int mins_total = 0;
                        for (uint g = 0u; g < 8u; g++) {
                            mins_total += int(mn[g]) * (q8_bsum(u, 2u * g) + q8_bsum(u, 2u * g + 1u));
                        }
                        mins[u] = fma32(-yd[u] * wdmin, float(mins_total), mins[u]);
                    }
                }
                int lk[PAIR_TILE];
                for (uint u = 0u; u < PAIR_TILE; u++) lk[u] = 0;
                for (uint g = 0u; g < 8u; g++) {
                    uint e = 32u * g + 4u * k;
                    int qv0 = int(q5_value(base, e + 0u));
                    int qv1 = int(q5_value(base, e + 1u));
                    int qv2 = int(q5_value(base, e + 2u));
                    int qv3 = int(q5_value(base, e + 3u));
                    int wsc = int(sc[g]);
                    for (uint u = 0u; u < PAIR_TILE; u++) {
                        if (!pair_live[u]) continue;
                        int s4 = qv0 * q8_i8(u, e + 0u)
                               + qv1 * q8_i8(u, e + 1u)
                               + qv2 * q8_i8(u, e + 2u)
                               + qv3 * q8_i8(u, e + 3u);
                        lk[u] += wsc * s4;
                    }
                }
                for (uint u = 0u; u < PAIR_TILE; u++) {
                    if (pair_live[u]) lane[u] = fma32(wd * yd[u], float(lk[u]), lane[u]);
                }
            } else if (pc.type == Q6_K) {
                float wd = load_f16(base + 208u);
                int lk[PAIR_TILE];
                for (uint u = 0u; u < PAIR_TILE; u++) lk[u] = 0;
                for (uint c = 0u; c < 8u; c++) {
                    uint e = 32u * c + 4u * k;
                    int qv0 = int(q6_value(base, e + 0u));
                    int qv1 = int(q6_value(base, e + 1u));
                    int qv2 = int(q6_value(base, e + 2u));
                    int qv3 = int(q6_value(base, e + 3u));
                    int wsc = load_i8(base + 192u + 2u * c + (k >> 2u));
                    for (uint u = 0u; u < PAIR_TILE; u++) {
                        if (!pair_live[u]) continue;
                        int s4 = qv0 * q8_i8(u, e + 0u)
                               + qv1 * q8_i8(u, e + 1u)
                               + qv2 * q8_i8(u, e + 2u)
                               + qv3 * q8_i8(u, e + 3u);
                        lk[u] += wsc * s4;
                    }
                }
                int wo0 = load_i8(base + 192u + 2u * k);
                int wo1 = load_i8(base + 192u + 2u * k + 1u);
                for (uint u = 0u; u < PAIR_TILE; u++) {
                    if (!pair_live[u]) continue;
                    lk[u] -= 32 * (q8_bsum(u, 2u * k) * wo0 + q8_bsum(u, 2u * k + 1u) * wo1);
                    lane[u] = fma32(wd * yd[u], float(lk[u]), lane[u]);
                }
            } else if (pc.type == IQ2_XXS) {
                int lk[PAIR_TILE];
                for (uint u = 0u; u < PAIR_TILE; u++) lk[u] = 0;
                for (uint ib = 0u; ib < 8u; ib++) {
                    uint q2 = base + 2u + ib * 8u;
                    uint aux0 = load_u16(q2) | (load_u16(q2 + 2u) << 16);
                    uint aux1 = load_u16(q2 + 4u) | (load_u16(q2 + 6u) << 16);
                    int ls = int(2u * (aux1 >> 28) + 1u);
                    uint l = k >> 1;
                    uint grid = TAB_XXS_GRID + ((aux0 >> (8u * l)) & 255u) * 2u;
                    uint sgn = tab_u8(TAB_KSIGNS, (aux1 >> (7u * l)) & 127u);
                    for (uint u = 0u; u < PAIR_TILE; u++) {
                        if (!pair_live[u]) continue;
                        lk[u] += ls * signed_grid4(grid, (k & 1u) * 4u, sgn, (k & 1u) * 4u,
                                                   u, ib * 32u + 4u * k);
                    }
                }
                for (uint u = 0u; u < PAIR_TILE; u++) {
                    if (pair_live[u]) lane[u] = fma32(wd * yd[u], float(lk[u]), lane[u]);
                }
            } else if (pc.type == IQ2_S) {
                uint qs = base + 2u;
                uint sgns = qs + 32u;
                uint qh = base + 66u;
                uint sc = base + 74u;
                int lk[PAIR_TILE];
                for (uint u = 0u; u < PAIR_TILE; u++) lk[u] = 0;
                for (uint ib = 0u; ib < 8u; ib++) {
                    uint scb = load_u8(sc + ib);
                    int ls = (k < 4u) ? (1 + 2 * int(scb & 15u)) : (1 + 2 * int(scb >> 4));
                    uint l = k >> 1;
                    uint qhb = load_u8(qh + ib);
                    uint grid = TAB_IQ2S_GRID +
                                ((load_u8(qs + 4u * ib + l) | ((qhb << (8u - 2u * l)) & 0x300u)) * 2u);
                    uint sgn = load_u8(sgns + 4u * ib + l);
                    for (uint u = 0u; u < PAIR_TILE; u++) {
                        if (!pair_live[u]) continue;
                        lk[u] += ls * signed_grid4(grid, (k & 1u) * 4u, sgn, (k & 1u) * 4u,
                                                   u, ib * 32u + 4u * k);
                    }
                }
                for (uint u = 0u; u < PAIR_TILE; u++) {
                    if (pair_live[u]) lane[u] = fma32(wd * yd[u], float(lk[u]), lane[u]);
                }
            } else if (pc.type == IQ3_S) {
                uint qs = base + 2u;
                uint qh = base + 66u;
                uint sgns = base + 74u;
                uint sc = base + 106u;
                int lk[PAIR_TILE];
                for (uint u = 0u; u < PAIR_TILE; u++) lk[u] = 0;
                for (uint ib = 0u; ib < 8u; ib++) {
                    uint scb = load_u8(sc + ib / 2u);
                    int ls = ((ib & 1u) == 0u) ? (2 * int(scb & 15u) + 1) : (2 * int(scb >> 4) + 1);
                    uint qhb = load_u8(qh + ib);
                    uint l = k >> 1;
                    /* iq3_s grids are 4 bytes; lane k uses entry 2*l + (k&1). */
                    uint pair_idx = 2u * l + (k & 1u);
                    uint entry = load_u8(qs + ib * 8u + pair_idx) | ((qhb << (8u - pair_idx)) & 256u);
                    uint sgn = load_u8(sgns + 4u * ib + l);
                    uint word = tables[TAB_IQ3S_GRID + entry];
                    for (uint u = 0u; u < PAIR_TILE; u++) {
                        int s4 = 0;
                        if (!pair_live[u]) continue;
                        for (uint j = 0u; j < 4u; j++) {
                            int prod = int((word >> (8u * j)) & 255u) * q8_i8(u, ib * 32u + 4u * k + j);
                            s4 += ((sgn >> ((k & 1u) * 4u + j)) & 1u) != 0u ? -prod : prod;
                        }
                        lk[u] += ls * s4;
                    }
                }
                for (uint u = 0u; u < PAIR_TILE; u++) {
                    if (pair_live[u]) lane[u] = fma32(wd * yd[u], float(lk[u]), lane[u]);
                }
            }
        }
        barrier();
    }

    for (uint u = 0u; u < PAIR_TILE; u++) sh_lane[u * 64u + lid] = lane[u];
    for (uint u = 0u; u < PAIR_TILE; u++) sh_min[u * 64u + lid] = mins[u];
    barrier();

    /* hsum_float_8 pair order, 0.125 applied to the total for the iq2
     * kernels like the AVX2 epilogue. */
    if (row_live && k == 0u) {
        uint r0 = lid;
        uint scale_idx = (pc.packed_weights != 0u) ? tile : expert;
        for (uint u = 0u; u < PAIR_TILE; u++) {
            uint p = pair[u];
            uint soff = u * 64u + r0;
            if (p == INVALID_PAIR) continue;
            float acc = ((sh_lane[soff + 0u] + sh_lane[soff + 4u]) + (sh_lane[soff + 2u] + sh_lane[soff + 6u]))
                      + ((sh_lane[soff + 1u] + sh_lane[soff + 5u]) + (sh_lane[soff + 3u] + sh_lane[soff + 7u]));
            if (pc.type == Q4_K) acc += (sh_min[soff + 0u] + sh_min[soff + 2u]) + (sh_min[soff + 1u] + sh_min[soff + 3u]);
            if (pc.type == Q5_K) acc += sh_min[soff];
            if (pc.type == IQ2_XXS || pc.type == IQ2_S) acc *= 0.125;
            if (pc.has_scales != 0u) acc *= scales[scale_idx];
            y[p * pc.out_dim + row] = acc;
        }
    }
}
